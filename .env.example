# WorkeaCheck™ — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Anthropic API Key
# ⚠️  In production, proxy all Anthropic calls through your own backend.
#    Direct browser access is only acceptable for prototyping.
#    See src/lib/intelligence.js for integration notes.
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase (Phase 2 — leave empty until backend integration)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Sheets Webhook (Apps Script URL for saving submissions)
VITE_GOOGLE_SHEETS_URL=

# QR Source identifier (set per deployment/QR placement)
# VITE_QR_SOURCE=coffee_area
